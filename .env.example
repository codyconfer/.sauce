# .sauce — sample environment for a non-interactive bootstrap.
#
# Every variable here pre-seeds the default for the matching chezmoi prompt in
# home/.chezmoi.toml.tmpl. Unset variables fall back to the built-in defaults
# (everything selected), so you only need to set the ones you want to change.
#
#   - Booleans must be exactly "true" or "false".
#   - List variables are space-separated (e.g. SAUCE_TOOLS="go k9s rustup"); the
#     literal value "none" selects an empty set.
#
# Because the prompts are "*Once", the value is only recorded the first time.
#
# Usage — copy, edit, export, then bootstrap or apply:
#
#   cp .env.example .env
#   $EDITOR .env
#   set -a; . ./.env; set +a          # export everything for this shell
#   bash ./bootstrap.sh                # (bootstrap.sh also auto-sources $SAUCE_DIR/.env)
#   # ...or, on an already-bootstrapped host:
#   chezmoi init --apply
#
# .env is gitignored — keep host-specific values out of the repo.

# --- desktop layer (Linux / macOS; ignored on WSL and native Windows) -------
# Headless machine — skips the entire desktop layer (emulators, GUI apps, Flatpaks).
export SAUCE_HEADLESS="false"
# Emulators. Choices: steam wine qemu
export SAUCE_EMULATORS="steam wine qemu"
# GUI apps. Choices: firefox sway gnuradio qdmr vscode zed codex cursor docker
#   ghidra jetbrains-toolbox lmstudio obsidian
export SAUCE_GUI_APPS="firefox sway gnuradio qdmr vscode zed codex cursor docker ghidra jetbrains-toolbox lmstudio obsidian"
# Flatpaks (Flathub). Choices: slack discord signal easyeffects obs-studio
#   bitwarden zen lutris retroarch zoom 1password chirp sonic-pi
export SAUCE_FLATPAKS="slack discord signal easyeffects obs-studio bitwarden zen lutris retroarch zoom 1password chirp sonic-pi"

# --- CLI / dev tools (all platforms) ----------------------------------------
# Choices: 1password-cli aws azure-cli bitwarden-cli cloudflared gcloud gcx
#   wrangler adb claude-code dotnet go k9s kubectl loglit nvim nvm ollama
#   opencode pi poetry pyenv rustup yarn
#   ...plus k3s, offered only when SAUCE_HEADLESS=true on a Linux host.
export SAUCE_TOOLS="1password-cli aws azure-cli bitwarden-cli cloudflared gcloud gcx wrangler adb claude-code dotnet go k9s kubectl loglit nvim nvm ollama opencode pi poetry pyenv rustup yarn"

# --- yes/no toggles ---------------------------------------------------------
# Common network/security CLI tools (nmap, dig, netcat, tcpdump, mtr, whois, ...).
export SAUCE_NET_TOOLS="true"
# Bring up Tailscale now (installs Tailscale and runs `sudo tailscale up`).
export SAUCE_TAILSCALE="false"

# --- native Windows only (winget) -------------------------------------------
# Set these in your PowerShell environment before `chezmoi init` on Windows.
# Choices — apps: vscode cursor zed obsidian docker-desktop jetbrains-toolbox
#   ghidra ollama lmstudio slack discord signal obs-studio bitwarden zen
#   retroarch zoom 1password
# Choices — tools: go dotnet aws gcloud azure-cli kubectl k9s node nvm yarn
#   neovim gh oh-my-posh cloudflared adb 1password-cli bitwarden-cli
#export SAUCE_WIN_APPS="vscode cursor zed"
#export SAUCE_WIN_TOOLS="go gh node nvm"
