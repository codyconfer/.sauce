# ~/.zshrc — managed by chezmoi (source: ~/.sauce). Edit via `chezmoi edit ~/.zshrc`.

# shared interactive shell logic (colors, banner, docker helper, update, get_secret, ...)
[ -f ~/.sauce/scripts/functions.sh ] && source ~/.sauce/scripts/functions.sh
_sauce_print_header

# aliases generated from ~/.sauce/scripts/*.sh (setup, onchange, update-*, update-all)
for _script in ~/.sauce/scripts/*.sh; do
    [ -e "$_script" ] || continue
    case "$_script" in */functions.sh) continue ;; esac   # sourced above, not aliased
    alias "$(basename "$_script" .sh)"="bash $_script"
done
unset _script

# tooling env/PATH — one runtime-guarded block per tool (a no-op if the tool is
# absent). Managed by chezmoi; keep the list in sync when adding a tool.
# dotnet
export DOTNET_ROOT="$HOME/.dotnet"
if [ -d "$DOTNET_ROOT" ]; then
    export PATH="$PATH:$DOTNET_ROOT:$DOTNET_ROOT/tools"
fi
# gcloud
[ -d "$HOME/google-cloud-sdk/bin" ] && export PATH="$HOME/google-cloud-sdk/bin:$PATH"
# Go
export PATH="$PATH:/usr/local/go/bin:$HOME/go/bin"
# lm studio cli
[ -d "$HOME/.lmstudio/bin" ] && export PATH="$PATH:$HOME/.lmstudio/bin"
export EDITOR="nvim"
export VISUAL="nvim"
alias vi="nvim"
alias vim="nvim"
# nvm
export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"
if [ -d "$NVM_DIR" ]; then
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
fi
# opencode
[ -d "$HOME/.opencode/bin" ] && export PATH="$HOME/.opencode/bin:$PATH"
# pyenv
export PYENV_ROOT="$HOME/.pyenv"
if [ -d "$PYENV_ROOT" ]; then
    command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
fi

# path
LOCAL_BIN="$HOME/.local/bin"
if [ -d "$LOCAL_BIN" ]; then
    export PATH="$LOCAL_BIN:$PATH"
fi

# history
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE INC_APPEND_HISTORY

# completion / autocomplete
setopt AUTO_MENU COMPLETE_IN_WORD ALWAYS_TO_END
fpath+=(~/.zfunc)
mkdir -p ~/.cache/zsh 2>/dev/null
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '%B%F{blue}%d%f%b'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.cache/zsh/zcompcache

# dotnet completion (dotnet ships no zsh completion of its own)
if command -v dotnet >/dev/null 2>&1; then
    _dotnet_zsh_complete() {
        local completions=("$(dotnet complete "$words")")
        if [ -z "$completions" ]; then
            _arguments '*::arguments: _normal'
            return
        fi
        _values = "${(ps:\n:)completions}"
    }
    compdef _dotnet_zsh_complete dotnet
fi

# prompt
eval "$(oh-my-posh init zsh --config ~/.config/oh-my-posh/sauce.toml)"

# your personal tweaks — kept in ~/.zshrc.local (created once, never touched by chezmoi)
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

# zsh plugins — loader generated by update-zsh-plugins.sh; sourced last so
# zsh-syntax-highlighting (which must load last) wraps everything above it.
[ -f "$HOME/.zsh/plugins.zsh" ] && source "$HOME/.zsh/plugins.zsh"
