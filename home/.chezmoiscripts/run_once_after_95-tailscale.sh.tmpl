#!/usr/bin/env bash

set -uo pipefail
source "$HOME/.sauce/scripts/lib/common.sh"
{{ if .tailscale }}
if ! command -v tailscale >/dev/null 2>&1; then
    log_download "Installing Tailscale..."
    fetch https://tailscale.com/install.sh | sh || { log_warn "tailscale install failed."; exit 0; }
fi
sudo tailscale up
{{ else }}
log_info "tailscale=false — skipping Tailscale setup."
{{ end }}
