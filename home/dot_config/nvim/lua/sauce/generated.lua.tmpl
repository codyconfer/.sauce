{{- /* Mirrors the toolchain detection in the old scripts/build-nvim.sh: enable
       the LSP servers + treesitter parsers for whatever language toolchains are
       present on this machine. Merged over the committed baseline in toolset.lua. */ -}}
{{- $servers := list -}}
{{- $parsers := list -}}
{{- if lookPath "go" }}{{ $servers = append $servers "gopls" }}{{ $parsers = concat $parsers (list "go" "gomod" "gosum") }}{{ end -}}
{{- if lookPath "python3" }}{{ $servers = append $servers "pyright" }}{{ $parsers = append $parsers "python" }}{{ end -}}
{{- if lookPath "ruff" }}{{ $servers = append $servers "ruff" }}{{ end -}}
{{- if lookPath "node" }}{{ $servers = append $servers "ts_ls" }}{{ $parsers = concat $parsers (list "typescript" "javascript" "tsx") }}{{ end -}}
{{- if lookPath "dotnet" }}{{ $servers = append $servers "omnisharp" }}{{ $parsers = append $parsers "c_sharp" }}{{ end -}}
{{- if or (lookPath "cargo") (lookPath "rustc") }}{{ $servers = append $servers "rust_analyzer" }}{{ $parsers = append $parsers "rust" }}{{ end -}}
{{- if lookPath "gcc" }}{{ $servers = append $servers "clangd" }}{{ $parsers = concat $parsers (list "c" "cpp") }}{{ end -}}
{{- if lookPath "docker" }}{{ $servers = append $servers "dockerls" }}{{ $parsers = append $parsers "dockerfile" }}{{ end -}}
-- AUTO-GENERATED by chezmoi (generated.lua.tmpl) -- do not edit.
-- Reflects language toolchains detected on this machine at `chezmoi apply` time.
return {
  servers = {
{{- range $servers }}
    {{ . | quote }},
{{- end }}
  },
  parsers = {
{{- range $parsers }}
    {{ . | quote }},
{{- end }}
  },
}
